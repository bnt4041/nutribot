# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
POSTGRES_USER=nutribot
POSTGRES_PASSWORD=nutribot
POSTGRES_DB=nutribot
DATABASE_URL=postgresql+asyncpg://nutribot:nutribot@db:5432/nutribot

# --- App ---
ENVIRONMENT=development

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- RAG / embeddings (TEI serving bge-m3) ---
EMBEDDINGS_URL=http://embeddings:80

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Dashboards ---
DASHBOARD_CLIENT_URL=http://localhost:5173
