# Production environment for the VPS. Copy to .env and fill in real values.
# NEVER commit the real .env.

# --- Database ---
POSTGRES_USER=nutribot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nutribot
DATABASE_URL=postgresql+asyncpg://nutribot:change-me-strong-password@db:5432/nutribot

# --- App ---
ENVIRONMENT=production

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Domains (point these DNS records to your VPS) ---
APP_DOMAIN=app.tudominio.com
ADMIN_DOMAIN=admin.tudominio.com
API_DOMAIN=api.tudominio.com
ACME_EMAIL=tu-email@tudominio.com

# DeepSeek pricing for cost metrics (USD per 1M tokens) — optional overrides.
# DEEPSEEK_PRICE_INPUT_PER_MTOK=0.27
# DEEPSEEK_PRICE_OUTPUT_PER_MTOK=1.10
